<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Address & Payment</title>
<style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
    background:#f4f4f4;
    min-height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;

    padding:20px;
}

        .container{
    width:100%;
    max-width:600px;
    background:white;
    padding:40px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.15);
}

        h1{
            text-align:center;
            color:#2c7a22;
            margin-bottom:30px;
        }

        .form-group{
            margin-bottom:20px;
        }

        label{
            display:block;
            margin-bottom:8px;
            font-weight:bold;
        }

        input{
            width:100%;
            padding:12px;
            border:1px solid #ccc;
            border-radius:8px;
            font-size:16px;
        }

        .price-box{
            margin-top:25px;
            padding:15px;
            background:#f0fff0;
            border:2px solid #3ca22c;
            border-radius:10px;
            text-align:center;
        }

        .price-box h2{
            color:#2c7a22;
        }

        button{
            width:100%;
            padding:15px;
            background:#3ca22c;
            color:white;
            border:none;
            border-radius:10px;
            font-size:18px;
            cursor:pointer;
            margin-top:20px;
            transition:0.3s;
        }

        button:hover{
            background:#2c7a22;
        }
    </style>
</head>
<body>

<div class="container">

    <h1>Enter Address & Payment</h1>

    <form action="/address" method="POST">

        <input type="hidden" name="data" value='<%- JSON.stringify(data) %>'>
        <input type="hidden" name="price" value="<%= price %>">

        <div class="form-group">
            <label>Pickup Address</label>
            <input type="text" name="paddress" required>
        </div>

        <div class="form-group">
            <label>Drop Address</label>
            <input type="text" name="daddress" required>
        </div>

        <div class="form-group">
            <label>Date</label>
            <input type="date" name="date" required>
        </div>

        <div class="form-group">
            <label>Time</label>
            <input type="time" name="time" required>
        </div>

        <div class="price-box">
            <h2>Total: ₹<%= price %></h2>
        </div>

        <button type="submit">
            Confirm Order
        </button>

    </form>

</div>

</body>
</html>
