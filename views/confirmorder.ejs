<!DOCTYPE html>
<html lang="en">
<head>
    <title>Order Confirmation</title>
    <link href="http://fonts.googleapis.com/css?family=Corben:bold" rel="stylesheet" type="text/css">
    <link href="http://fonts.googleapis.com/css?family=Nobile" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="/css/font-awesome.css">

    <style>
        body {
            background: linear-gradient(to right, #505050, #ffffff);
            color: #222;
            font-family: 'Nobile', Helvetica, Arial, sans-serif;
            padding: 50px;
        }
        .cont {
            background: linear-gradient(to right, #505050, #ffffff);
            padding: 20px;
            text-align: center;
            border-radius: 5px;
        }
        h1 {
            font-family: 'Corben', Georgia, Times, serif;
            color: white;
            margin: 0;
            text-shadow: 1px 1px 1px #ccc;
        }
        main {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }
        .order-summary {
            background-color: grey;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 1em 1em #ccc;
            color: #fff;
        }
        .order-summary h2 {
            font-family: 'Corben', Georgia, Times, serif;
            margin-top: 0;
        }
        .order-summary p {
            font-size: 1.2em;
            margin-bottom: 10px;
        }
        .order-summary span {
            font-weight: bold;
        }
        #print-button {
            background-color: #006400;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 1.2em;
            cursor: pointer;
            border-radius: 5px;
            margin-top: 20px;
        }
        #print-button:hover {
            background-color: #008000;
        }

        /* Navbar */
        * { padding: 0; margin: 0; }
        .navbar {
            top: 0;
            left: 0;
            width: 100%;
            height: 100px;
            background-color: #ffffff;
            display: flex;
            align-items: center;
            position: fixed;
            margin-bottom: 10px;
            z-index: 1000;
        }
        #logo {
            margin: 20px;
            height: 60px;
            margin-right: 200px;
        }
        .navbar a {
            font-size: 22px;
            margin: 20px;
            color: black;
            text-decoration: none;
            font-weight: 700;
        }
        .navbar a:hover {
            color: #3ca22c;
            text-decoration: underline;
        }
        .content {
            margin-top: 120px;
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const printButton = document.getElementById("print-button");
            if (printButton) {
                printButton.addEventListener("click", function() {
                    window.print();
                });
            }
        });
    </script>
</head>
<body>
    <!-- ✅ Navbar -->
    <div class="navbar">
        <img src="/images/logo.png" id="logo">
        <a href="/home">Home</a>
        <a href="/about">About</a>
        <a href="/service">Services</a>
        <a href="/contact">Contact</a>
        <a href="/order">Order</a>
        <% if (islogin) { %>
            <a href="/profile">Profile</a>
            <a href="/logout">Logout</a>
        <% } else { %>
            <a href="/login">Login</a>
            <a href="/signup">Signup</a>
        <% } %>
    </div>

    <!-- ✅ Confirmation Content -->
    <div class="content">
        <div class="cont">
            <h1>Order Confirmation</h1>
        </div>

        <main>
            <section class="order-summary">
                <h2>Order Summary</h2>
                <p id="order-number">Order Number: <span><%= order._id %></span></p>
                <p id="order-date">Pickup Date: <span><%= order.date %></span></p>
                <p id="order-total">Total: <span>₹<%= order.price %></span></p>

                <h3>Items</h3>
                <ul>
                    <li>Shirts: <%= order.shirts %></li>
                    <li>Pants: <%= order.pants %></li>
                    <li>Suits: <%= order.suits %></li>
                    <li>Sarees: <%= order.sarees %></li>
                    <li>Jackets: <%= order.jackets %></li>
                    <li>Others: <%= order.others %></li>
                    <li>Socks: <%= order.socks %></li>
                </ul>

                <h3>Addresses</h3>
                <p>Pickup: <%= order.pickup_address %></p>
                <p>Drop: <%= order.drop_address %></p>
                <p>Time: <%= order.time %></p>
            </section>

            <button id="print-button"><i class="icon-truck"></i> Print Receipt</button>
        </main>
    </div>
</body>
</html>
